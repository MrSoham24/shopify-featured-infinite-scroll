{{ 'custom.css' | asset_url | stylesheet_tag }}
<script src="{{ 'custom.js' | asset_url }}" defer></script>

<div class="custom-collection-section">

  <!-- Product container -->
  <div id="product-container" class="product-grid" data-collection-handle="{{ collection.handle }}"></div>

  <!-- Loader OUTSIDE -->
  <div class="loader" style="display:none;">
    Loading products...
  </div>

</div>

{% schema %}
{
  "name": "Custom Collection",
  "settings": [],
  "presets": [
    {
      "name": "Custom Collection"
    }
  ]
}
{% endschema %}
